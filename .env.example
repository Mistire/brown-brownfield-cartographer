# OpenRouter API (required for LLM features)
OPENROUTER_API_KEY=your_key_here
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Model routing — the system auto-selects the right model based on prompt size.
# You can pin specific models with these overrides, or leave them unset for auto-routing.
# LLM_LOW_MODEL  — used as the default warm-up model (small prompts, ~32k ctx)
# LLM_HIGH_MODEL — legacy override for large-file analysis (optional)
# NAVIGATOR_MODEL — pin the Navigator's tool-calling model (optional, auto-selects if unset)
LLM_LOW_MODEL=mistralai/mistral-small-3.1-24b-instruct:free
LLM_HIGH_MODEL=meta-llama/llama-3.3-70b-instruct:free
NAVIGATOR_MODEL=meta-llama/llama-3.3-70b-instruct:free
EMBEDDING_MODEL=
# Set EMBEDDING_MODEL only if you have a dedicated embeddings endpoint.
# Leave empty to use the built-in hash-based fallback (OpenRouter doesn't support /embeddings).

# WebSocket limits
WS_MAX_MESSAGE_BYTES=65536
WS_IDLE_TIMEOUT_SECS=300

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# LangChain / LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=brownfield-cartographer
